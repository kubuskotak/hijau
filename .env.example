# Copy to .env for local dev. mise loads .env automatically.
DATABASE_URL=postgres://hijau:hijau@localhost:5433/hijau?sslmode=disable
PUBLIC_URL=http://localhost:8080
PORT=8080

# 32+ byte random string for signing session cookies
SESSION_SECRET=dev-session-secret-change-me-please-32b
# Exactly 32 bytes (AES-256-GCM) — encrypts stored MT provider credentials & API keys
HIJAU_ENCRYPTION_KEY=dev-encryption-key-change-me-0123456789

# Comma-separated allowlist of app origins for CORS (in-context editor / web dev server)
CORS_ORIGINS=http://localhost:5173

# Screenshot storage: fs (local) | s3
HIJAU_STORAGE=fs
HIJAU_STORAGE_DIR=./data/screenshots

# Set to 1 to seed a demo org/project/user on boot
# HIJAU_SEED=0
